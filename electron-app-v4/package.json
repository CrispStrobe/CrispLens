{
  "name": "crisplens-v4",
  "version": "0.1.0",
  "description": "CrispLens v4 – pure Node.js, Python-free, cross-platform",
  "author": "CrispStrobe",
  "main": "electron-main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:electron": "electron .",
    "dev": "ELECTRON_DEV=1 electron .",
    "dev:server": "node server.js",
    "dev:ui": "cd renderer && npm run dev",
    "build:ui": "cd renderer && npm run build",
    "build:electron": "npm run build:ui && electron-builder",
    "build:mac": "npm run build:ui && electron-builder --mac && npm rebuild",
    "build:win": "npm run build:ui && electron-builder --win && npm rebuild",
    "build:linux": "npm run build:ui && electron-builder --linux",
    "build:all": "npm run build:ui && electron-builder --mac --win --linux && npm rebuild",
    "proto": "node proto-test.js",
    "self-test": "node proto-selfcontained.js",
    "self-test:db": "node proto-selfcontained.js ../face_recognition.db",
    "download-models": "node core/model-downloader.js",
    "mobile:setup:ios": "cd renderer && npm install && npx cap add ios",
    "mobile:setup:android": "cd renderer && npm install && npx cap add android",
    "mobile:sync": "npm run build:ui && cd renderer && npx cap sync",
    "mobile:open:ios": "cd renderer && npx cap open ios",
    "mobile:open:android": "cd renderer && npx cap open android",
    "mobile:run:ios": "npm run build:ui && cd renderer && npx cap run ios",
    "mobile:run:android": "npm run build:ui && cd renderer && npx cap run android"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^11.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.5",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "onnxruntime-node": "^1.20.1",
    "sharp": "^0.33.5",
    "usearch": "^2.21.4",
    "uuid": "^11.0.5"
  },
  "optionalDependencies": {
    "faiss-node": "^0.5.1"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.crisplens.v4",
    "productName": "CrispLens",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**",
      "node_modules/usearch/**"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "server.js",
      "server/**",
      "core/**",
      "assets/**",
      "!test-data/**",
      "!renderer/**",
      "!node_modules/electron/**",
      "!**/*.md"
    ],
    "extraResources": [
      {
        "from": "renderer/dist",
        "to": "renderer/dist",
        "filter": [
          "**/*",
          "!models/**",
          "!ort-wasm/*.wasm",
          "!assets/*.wasm"
        ]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "files": [
        "electron-main.js",
        "preload.js",
        "server.js",
        "server/**",
        "core/**",
        "assets/**",
        "!test-data/**",
        "!renderer/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/@img/sharp-linux-x64/**",
        "!node_modules/@img/sharp-win32-x64/**"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.photography"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "files": [
        "electron-main.js",
        "preload.js",
        "server.js",
        "server/**",
        "core/**",
        "assets/**",
        "!test-data/**",
        "!renderer/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
        "!node_modules/@img/sharp-linux-x64/**",
        "!node_modules/@img/sharp-darwin-arm64/**"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "files": [
        "electron-main.js",
        "preload.js",
        "server.js",
        "server/**",
        "core/**",
        "assets/**",
        "!test-data/**",
        "!renderer/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
        "!node_modules/@img/sharp-win32-x64/**",
        "!node_modules/@img/sharp-darwin-arm64/**"
      ],
      "icon": "assets/icon.png",
      "category": "Graphics"
    }
  },
  "_platform_notes": {
    "browser_pwa": {
      "description": "Build renderer only: cd renderer && npm run build — produces a PWA in renderer/dist",
      "server": "node server.js serves the PWA at http://localhost:7861",
      "onnxruntime-node": "→ onnxruntime-web  (same models, WASM/WebGL/WebGPU backends)",
      "sharp": "→ OffscreenCanvas  (built-in; face-align.js math is unchanged)",
      "better-sqlite3": "→ sql.js or @capacitor-community/sqlite  (WASM SQLite)"
    },
    "mobile_capacitor": {
      "description": "cd renderer && npx cap add ios / npx cap add android",
      "server": "Point capacitor.config.ts server.url to your deployed Node.js API"
    }
  }
}

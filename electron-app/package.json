{
  "name": "face-recognition-system",
  "version": "1.0.0",
  "description": "Self-hosted face recognition and photo management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "build:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.facerec.app",
    "productName": "Face Recognition System",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Face Recognition System",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "license": null
    },
    "files": [
      "main.js",
      "preload.js",
      "python-manager.js",
      "renderer/**",
      "assets/**",
      "!assets/README.md"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app",
        "filter": [
          "**/*.py",
          "schema_complete.sql",
          "config.example.yaml",
          "requirements.txt",
          "!venv/**",
          "!**/*.db",
          "!.api_secret_key",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!electron-app/**",
          "!logs/**",
          "!thumbnails/**",
          "!exports/**",
          "!datasets/**",
          "!backups/**",
          "!bkp/**"
        ]
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}

# ============================================================================
# Face Recognition System - .gitignore
# ============================================================================

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv/
virtualenv/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python build lib dirs (but NOT src/lib/ in Svelte apps)
/lib/
/lib64/
!electron-app-v2/renderer/src/lib/
# Svelte compiled frontends — include in git so VPS deployment works without Node
!electron-app-v2/renderer/dist/
!electron-app-v4/renderer/dist/
# But exclude very large binary assets from v4 dist that can't go on GitHub
electron-app-v4/renderer/dist/models/
electron-app-v4/renderer/dist/ort-wasm/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
electron-app-v4/test-data/

# ============================================================================
# electron-app-v4 build output
# ============================================================================
# Electron installer/app bundle output (DMG, NSIS, AppImage, .app, blockmaps)
electron-app-v4/dist-electron/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# ============================================================================
# Database Files
# ============================================================================
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
face_recognition.db*
*.backup

# FAISS Index
*.index
face_vectors.index

# ============================================================================
# Logs and Runtime Data
# ============================================================================
*.log
logs/
audit.log
face_recognition.log

# ============================================================================
# Temporary Files
# ============================================================================
/tmp/
temp/
*.tmp
*.temp
/tmp/gradio_*/
.gradio/

# ============================================================================
# User Data and Uploads
# ============================================================================
uploads/
training_data/
processed_images/
backups/
exports/
thumbnails/

# Datasets (uncomment if you want to track datasets)
datasets/
# !datasets/.gitkeep  # Uncomment to keep directory

# ============================================================================
# Configuration and Secrets
# ============================================================================
# Sensitive configuration (IMPORTANT!)
config.yaml
config.yml
.env
.env.local
.env.*.local
*.key
*.pem
*.cert
credentials/
secrets/
api_keys.txt

# Encrypted key file (generated by api_key_manager.py — never commit this)
.api_secret_key

# Keep example config
!config.example.yaml
!config.template.yaml

# ============================================================================
# macOS
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ============================================================================
# Linux
# ============================================================================
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================================================
# Windows
# ============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# ============================================================================
# IDEs and Editors
# ============================================================================

# VSCode
.vscode/
.history/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist
tags
[._]*.un~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================================================
# Project Specific
# ============================================================================

# Environment info
.env_info

# Activation scripts (generated by setup)
# activate.sh  # Uncomment if you want to ignore
# run.sh       # Uncomment if you want to ignore

# Model files (if you download them)
models/
*.onnx
*.pth
*.pt
*.h5
*.pkl
*.pickle

# Large test datasets
datasets/att_faces/
datasets/lfw/
datasets/celeba/

# Local backup / scratch directory
bkp/

# Gradio cache
.gradio/

# Face crops (if extracted)
face_crops/

# Test outputs
test_outputs/
demo_images/

# ============================================================================
# Documentation
# ============================================================================
# Build documentation
docs/_build/
docs/.doctrees/
site/

# ============================================================================
# Misc
# ============================================================================
*.bak
*.swp
*.swo
*.orig
.project
.pydevproject
.settings/
*.launch

# Compressed files
*.zip
*.tar.gz
*.rar
*.7z

# Large media files (optional - adjust as needed)
# *.mp4
# *.avi
# *.mov
# *.mkv

# ============================================================================
# Security Scanning
# ============================================================================
.snyk
.bandit

# ============================================================================
# CI/CD  (these files should be tracked — do NOT ignore them)
# ============================================================================
# .github/
# .gitlab-ci.yml
# .travis.yml
# circle.yml

# ============================================================================
# Keep These Directories (but ignore contents)
# ============================================================================
# Create empty directories with .gitkeep files

!backups/.gitkeep
!logs/.gitkeep
!exports/.gitkeep
!datasets/.gitkeep
!thumbnails/.gitkeep
node_modules/
.vercel
